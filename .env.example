# Lotus — variáveis de ambiente (exemplo)
# Copie para .env e preencha com os valores do projeto.
# Documentação completa: docs/ENVIRONMENT_VARIABLES.md
# Prefixo OFFICIAL_ (não SUPABASE_) — reservado pelo preset Lovable.

# =============================================================================
# 1. Supabase — browser (expostas via Vite — prefixo VITE_)
# =============================================================================
VITE_OFFICIAL_SUPABASE_URL=https://ywvhoctcmibjitvwkkhb.supabase.co
VITE_OFFICIAL_SUPABASE_ANON_KEY=your-anon-key-here
VITE_OFFICIAL_SUPABASE_PROJECT_ID=ywvhoctcmibjitvwkkhb

# =============================================================================
# 2. Supabase — servidor (NUNCA prefixar service-role com VITE_)
# =============================================================================
OFFICIAL_SUPABASE_URL=https://ywvhoctcmibjitvwkkhb.supabase.co
OFFICIAL_SUPABASE_ANON_KEY=your-anon-key-here
OFFICIAL_SERVICE_ROLE_KEY=your-service-role-key-here

# =============================================================================
# 3. URL pública do portal (convites, OAuth callbacks, links transacionais)
# =============================================================================
# OBRIGATÓRIO em produção. Local: http://localhost:5173 (sem barra final)
APP_URL=http://localhost:5173

# Opcionais — aliases aceitos por app-url.server.ts
# SITE_URL=https://lotsbi.leandromajr.com
# VITE_APP_URL=http://localhost:5173
# PUBLIC_APP_URL=https://lotsbi.leandromajr.com

# Diagnóstico de auth (/admin/debug) — opcional
OFFICIAL_PRODUCTION_APP_URL=https://lotsbi.leandromajr.com
# PRODUCTION_APP_URL=https://lotsbi.leandromajr.com
# STAGING_APP_URL=https://preview.lotsbi.example.com

# =============================================================================
# 4. Platform Hub — writers e homologação
# =============================================================================
# Destino: HUB (default) | BOTH | MAKE (bloqueado no Hub)
PLATFORM_HUB_WRITER_TARGET=HUB

# Habilita escrita em base_metricas_hub via SupabaseWriter
# Admin stack força true; kernel passivo usa default false se ausente
PLATFORM_HUB_SUPABASE_WRITER=true

# Criptografia do Credential Vault (ph_credentials)
# Recomendado em staging/prod; fallback: OFFICIAL_SERVICE_ROLE_KEY
# HUB_CREDENTIAL_ENCRYPTION_KEY=generate-with-openssl-rand-base64-32

# =============================================================================
# 5. Platform Hub — OAuth (obrigatório ao conectar official_api no admin)
# =============================================================================

# --- Google (Ads, GA4, Google Business, YouTube) ---
# Redirect URI: {APP_URL}/oauth/google/callback
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-your-google-client-secret

# Google Ads API — obrigatório para collect/discovery Google Ads
GOOGLE_ADS_DEVELOPER_TOKEN=your-google-ads-developer-token

# --- Meta Ads ---
# Redirect URI: {APP_URL}/oauth/meta/callback
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret

# --- TikTok ---
# Redirect URI: {APP_URL}/oauth/tiktok/callback
TIKTOK_APP_ID=your-tiktok-app-id
TIKTOK_APP_SECRET=your-tiktok-app-secret

# =============================================================================
# 6. Gate A — paridade Meta (CLI / engenharia — não usado pela UI admin)
# =============================================================================
# GATE_A_CONFIG=./path/to/gate-a.config.json
# GATE_A_META_ACCESS_TOKEN=EAAG...
# META_ACCESS_TOKEN=EAAG...
# GATE_A_MODE=live
# GATE_A_DISCOVER=1
# GATE_A_DISCOVER_FROM=2026-07-01
# GATE_A_DISCOVER_TO=2026-07-07
# GATE_A_DISCOVER_MIN_ROWS=100
# GATE_A_DISCOVER_LIMIT=20

# =============================================================================
# 7. Deploy (GitHub Actions / wrangler — não necessário para npm run dev)
# =============================================================================
# CLOUDFLARE_API_TOKEN=cf_your_cloudflare_api_token
