# Lotus — variáveis de ambiente (exemplo)
# Copie para .env e preencha com os valores do projeto Supabase.
# Prefixo OFFICIAL_ (não SUPABASE_) — reservado pelo preset Lovable.

# --- Browser (expostas via Vite — prefixo VITE_) ---
VITE_OFFICIAL_SUPABASE_URL=https://ywvhoctcmibjitvwkkhb.supabase.co
VITE_OFFICIAL_SUPABASE_ANON_KEY=your-anon-key-here
VITE_OFFICIAL_SUPABASE_PROJECT_ID=ywvhoctcmibjitvwkkhb

# --- Servidor (NUNCA prefixar service-role com VITE_) ---
OFFICIAL_SUPABASE_URL=https://ywvhoctcmibjitvwkkhb.supabase.co
OFFICIAL_SUPABASE_ANON_KEY=your-anon-key-here
OFFICIAL_SERVICE_ROLE_KEY=your-service-role-key-here

# URL pública do portal (convites por e-mail) — sem barra no final
# OBRIGATÓRIO em produção (Lovable/Cloudflare secrets). Local: http://localhost:5173
APP_URL=http://localhost:5173

# Domínio oficial de produção (validação de auth — opcional se for o padrão)
OFFICIAL_PRODUCTION_APP_URL=https://lotsbi.leandromajr.com

# Homologação / preview (opcional)
# STAGING_APP_URL=https://preview.lotsbi.example.com
